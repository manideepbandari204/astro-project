---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import FeedbackCard from '../components/FeedbackCard.astro';

const WORKER =
  import.meta.env.PUBLIC_WORKER_URL ||
  'https://worker-api.feedback-api-manideep.workers.dev';
---

<Base title="AnonWall — Feedback Wall">

  <Navbar />

  <main class="page">

    <!-- HERO -->
    <section class="hero">

      <p class="eyebrow">Live · Anonymous · Unfiltered</p>

      <h1 class="headline">The <em>Wall</em></h1>

      <p class="sub">
        <span id="count">0</span> messages loaded
      </p>

    </section>

    <!-- SEARCH + REFRESH -->
    <div class="search-row">

      <input
        type="search"
        id="searchInput"
        placeholder="Search messages..."
        class="search-input"
      />

      <button id="refreshBtn">↻</button>

    </div>

    <!-- WALL (IMPORTANT: EMPTY INITIALLY) -->
    <div class="wall" id="wall"></div>

  </main>

  <!-- SCRIPT -->
  <script define:vars={{ WORKER }}>

    const wall = document.getElementById("wall");
    const searchInput = document.getElementById("searchInput");
    const count = document.getElementById("count");
    const refreshBtn = document.getElementById("refreshBtn");

    let allMessages = [];

    // ---------------------------
    // RENDER FUNCTION
    // ---------------------------
    function renderMessages(data) {
      allMessages = data;

      if (!wall) return;

      wall.innerHTML = data.map((m) => {
        return `
          <div class="card">
            <h3>${m.name || "Anonymous"}</h3>
            <p>${m.message}</p>
            <small>${new Date(m.created_at).toLocaleString()}</small>
          </div>
        `;
      }).join("");

      count.textContent = data.length;
    }

    // ---------------------------
    // FETCH DATA
    // ---------------------------
    async function loadMessages() {
      try {
        const res = await fetch(`${WORKER}/api/messages`);
        const data = await res.json();

        renderMessages(data || []);

      } catch (err) {
        console.error("Fetch error:", err);
      }
    }

    // ---------------------------
    // SEARCH
    // ---------------------------
    searchInput?.addEventListener("input", (e) => {
      const q = e.target.value.toLowerCase();

      const filtered = allMessages.filter((m) =>
        (m.name || "").toLowerCase().includes(q) ||
        (m.message || "").toLowerCase().includes(q)
      );

      renderMessages(filtered);
    });

    // ---------------------------
    // REFRESH BUTTON
    // ---------------------------
    refreshBtn?.addEventListener("click", loadMessages);

    // ---------------------------
    // INITIAL LOAD
    // ---------------------------
    loadMessages();

  </script>

</Base>

<style>

.page {
  max-width: 700px;
  margin: auto;
  padding: 40px;
}

.hero {
  text-align: center;
  margin-bottom: 30px;
}

.headline {
  font-size: 3rem;
}

.search-row {
  display: flex;
  gap: 10px;
  margin-bottom: 20px;
}

.search-input {
  flex: 1;
  padding: 10px;
}

.wall {
  display: grid;
  gap: 15px;
}

.card {
  padding: 15px;
  border: 1px solid #ddd;
  border-radius: 10px;
}

button {
  padding: 10px 15px;
  cursor: pointer;
}

</style>