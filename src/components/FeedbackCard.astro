---
export interface Props {
  name: string;
  message: string;
  created_at: string;
  index?: number;
}
const { name, message, created_at, index = 0 } = Astro.props;

// Format timestamp
function formatTime(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleString('en-US', {
    month: 'short', day: 'numeric', year: 'numeric',
    hour: '2-digit', minute: '2-digit',
  });
}

const initials = (name || 'A').slice(0, 2).toUpperCase();
// Deterministic hue from name
const hue = [...(name || 'X')].reduce((a, c) => a + c.charCodeAt(0), 0) % 360;
---
<article class="card" style={`animation-delay:${index * 60}ms`}>
  <div class="card-top">
    <div class="avatar" style={`--hue:${hue}`}>
      {initials}
    </div>
    <div class="meta">
      <span class="author">{name || 'Anonymous'}</span>
      <time class="time" datetime={created_at}>{formatTime(created_at)}</time>
    </div>
  </div>
  <p class="msg">{message}</p>
</article>

<style>
.card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  opacity: 0;
  animation: fadeUp .5s ease forwards;
  transition: background .2s, border-color .2s, transform .2s;
}
.card:hover {
  background: var(--card-hover);
  border-color: var(--border-g);
  transform: translateY(-2px);
}
.card-top {
  display: flex;
  align-items: center;
  gap: 12px;
}
.avatar {
  width: 38px; height: 38px; border-radius: 10px;
  background: hsl(var(--hue,220), 40%, 22%);
  border: 1px solid hsl(var(--hue,220), 40%, 35%);
  color: hsl(var(--hue,220), 60%, 72%);
  display: grid; place-items: center;
  font-family: var(--ff-d); font-size: .8rem; font-weight: 700;
  flex-shrink: 0;
}
.meta { display: flex; flex-direction: column; gap: 1px; }
.author {
  font-weight: 600; font-size: .875rem; color: var(--txt);
  font-family: var(--ff-u);
}
.time {
  font-family: var(--ff-m); font-size: .72rem;
  color: var(--txt3); letter-spacing: .02em;
}
.msg {
  font-size: .95rem; color: var(--txt2); line-height: 1.65;
  white-space: pre-wrap; word-break: break-word;
}
</style>
